{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "installCommand": "npm install",
    "env": {
      "NIXPACKS_NODE_VERSION": "22.12.0"
    }
  },
  "deploy": {
    "startCommand": "node server/index.js",
    "healthcheckPath": "/api/posts"
  }
}
